// ──────────────────────────────────────────────────────────────────────────────
// CUSTOM PAINTER - Çizgiler
// ──────────────────────────────────────────────────────────────────────────────

class _WordLinePainter extends CustomPainter {
  final List<Map<String, dynamic>> paths;
  final double cs;
  final double opacity;
  final bool isDashed;

  _WordLinePainter(this.paths, this.cs, this.opacity, {this.isDashed = false});

  @override
  void paint(Canvas canvas, Size size) {
    for (final p in paths) {
      final cells = p['cells'] as List<Offset>;
      if (cells.isEmpty) continue;

      final color = (p['color'] as Color).withOpacity(opacity);
      final pts = cells
          .map((c) => Offset(c.dx * cs + cs / 2, c.dy * cs + cs / 2))
          .toList();

      if (cells.length == 1) {
        canvas.drawCircle(
            pts.first,
            cs * 0.22,
            Paint()
              ..color = color
              ..style = PaintingStyle.fill);
        continue;
      }

      final strokeW = cs * 0.40;

      // Glow efekti
      canvas.drawLine(
          pts.first,
          pts.last,
          Paint()
            ..color = color.withOpacity(0.25)
            ..strokeWidth = strokeW + 10
            ..strokeCap = StrokeCap.round
            ..style = PaintingStyle.stroke
            ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 8));

      // Ana çizgi
      canvas.drawLine(
          pts.first,
          pts.last,
          Paint()
            ..color = color
            ..strokeWidth = strokeW
            ..strokeCap = StrokeCap.round
            ..style = PaintingStyle.stroke);

      // Bitiş noktaları
      final cap = Paint()
        ..color = color
        ..style = PaintingStyle.fill;
      canvas.drawCircle(pts.first, cs * 0.22, cap);
      canvas.drawCircle(pts.last, cs * 0.22, cap);
    }
  }

  @override
  bool shouldRepaint(_WordLinePainter old) => true;
}

