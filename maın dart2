  ];

  String get _currentBg => _backgrounds[(level - 1) % _backgrounds.length];

  // ── KOLAY'DAN ZORA: Level bazlı ızgara boyutu ──────────────────────────────
  // Level  1-3  → 8×8   (çok kolay, geniş hücreler, net okuma)
  // Level  4-6  → 10×10 (orta-kolay)
  // Level  7-10 → 12×12 (orta)
  // Level 11-15 → 13×13 (orta-zor)
  // Level 16-20 → 14×14 (zor)
  // Level 21+   → 15×15 (çok zor)
  int _gridSizeForLevel(int lv) {
    if (lv <= 3) return 8;
    if (lv <= 6) return 10;
    if (lv <= 10) return 12;
    if (lv <= 15) return 13;
    if (lv <= 20) return 14;
    return 15;
  }

  @override
  void initState() {
    super.initState();
    t = translations[widget.lang] ?? translations['en']!;

    _pulseCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 700))
      ..repeat(reverse: true);
    _successCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 500));
    _successScale = Tween(begin: 0.5, end: 1.0).animate(
        CurvedAnimation(parent: _successCtrl, curve: Curves.elasticOut));

    _gridEnterCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 600));
    _gridEnterAnim =
        CurvedAnimation(parent: _gridEnterCtrl, curve: Curves.easeOutCubic);

    _adsRemoved = widget.adsRemoved;

    _loadCoins();
    _loadSavedData();
    _loadAdsRemovedStatus();

    if (AppSettings.musicEnabled) _startMusic();
  }

  Future<void> _loadAdsRemovedStatus() async {
    final prefs = await SharedPreferences.getInstance();
    final savedRemoved = prefs.getBool('ads_removed') ?? false;

    if (savedRemoved != _adsRemoved) {
      setState(() => _adsRemoved = savedRemoved);
    }

    if (!_adsRemoved) {
      _loadBannerAd();
      _loadInterstitialAd();
    } else {
      _bannerAd?.dispose();
      _bannerAd = null;
      _isBannerLoaded = false;
      _interstitialAd?.dispose();
      _interstitialAd = null;
    }
  }

  Future<void> _loadCoins() async {
    final prefs = await SharedPreferences.getInstance();
