  void _useTip() {
    if (foundWords.length >= words.length) return;
    final remaining = words.where((w) => !foundWords.contains(w)).toList();
    if (remaining.isEmpty) return;
    final word = remaining[rand.nextInt(remaining.length)];
    setState(() => tipJokers--);
    _saveData();
    _showTipOverlay(word);
  }

  void _showTipOverlay(String word) {
    final tip = word.length > 2
        ? '${word[0]}${'_' * (word.length - 2)}${word[word.length - 1]}'
        : word[0];
    showDialog(
        context: context,
        barrierColor: Colors.transparent,
        builder: (_) => _TipOverlay(tip: tip, word: word));
  }

  bool _checkDir(String w, int r, int c, int dr, int dc) {
    for (int i = 0; i < w.length; i++) {
      final nr = r + i * dr, nc = c + i * dc;
      if (!_inBounds(nr, nc)) return false;
      if (grid[nr][nc] != w[i]) return false;
    }
    return true;
  }

  void _openStore() {
    Navigator.push(
        context,
        MaterialPageRoute(
            builder: (_) => PremiumScreen(
                lang: widget.lang,
                onPurchase: (addedCoins, removeAds) {
                  setState(() {
                    coins += addedCoins;
                    if (removeAds) {
                      _adsRemoved = true;
                      _bannerAd?.dispose();
                      _bannerAd = null;
                      _isBannerLoaded = false;
                      _interstitialAd?.dispose();
                      _interstitialAd = null;
                    }
                  });
                  _saveCoins();
                  if (removeAds && mounted)
                    _showToast('🎉 Reklamlar kaldırıldı! Teşekkürler!');
                }))).then((_) async {
      await _loadAdsRemovedStatus();
      await _loadCoins();
      if (mounted) setState(() {});
    });
  }

  void _showErrorDialog(String msg) {
    if (!mounted) return;
    showDialog(
        context: context,
        barrierDismissible: false,
        builder: (_) => _ErrorDialog(
            message: msg,
            onMenu: () => Navigator.popUntil(context, (r) => r.isFirst)));
  }

  void _showPauseMenu() {
    setState(() => isPaused = true);
    showDialog(
        context: context,
        barrierDismissible: false,
        barrierColor: Colors.black.withOpacity(0.7),
        builder: (_) => _PauseDialog(
            t: t,
            onResume: () {
              Navigator.pop(context);
              setState(() => isPaused = false);
            },
            onMenu: () {
              _gameTimer?.cancel();
              Navigator.popUntil(context, (r) => r.isFirst);
            },
            onRestart: () {
              Navigator.pop(context);
              setState(() {
                isPaused = false;
              });
              _newGame();
            }));
  }

  void _showWinDialog() async {
    if (!mounted || _winDialogShown) return;
    _winDialogShown = true;
    _gameTimer?.cancel();
    _haptic(heavy: true);
    await _saveData();

    showDialog(
      context: context,
      barrierDismissible: false,
      barrierColor: Colors.black.withOpacity(0.75),
      builder: (_) => _WinDialog(
        t: t,
        level: level,
        seconds: seconds,
        score: score,
        wordsFound: foundWords.length,
        totalWords: words.length,
        canGoNext: level < maxSupportedLevel,
        onMenu: () {
          Navigator.popUntil(context, (r) => r.isFirst);
          if (level % 2 == 0 && !_adsRemoved) _showInterstitial();
        },
        onNext: () {
          Navigator.pop(context);
          if (level % 2 == 0 && !_adsRemoved)
            Future.delayed(
                const Duration(milliseconds: 300), _showInterstitial);
          if (!mounted) return;
          setState(() {
            level++;
            _winDialogShown = false;
          });
          _loadWordsAndStart();
        },
        onFinish: () {
          Navigator.pop(context);
          showDialog(
              context: context,
              builder: (_) => _AllDoneDialog(
                  message: t['game_completed']!,
                  onMenu: () => Navigator.popUntil(context, (r) => r.isFirst)));
        },
      ),
    );
  }

  void _showInterstitial() {
    if (_interstitialAd == null || _adsRemoved) return;
    _interstitialAd!.fullScreenContentCallback =
        FullScreenContentCallback(onAdDismissedFullScreenContent: (ad) {
      ad.dispose();
      _loadInterstitialAd();
    }, onAdFailedToShowFullScreenContent: (ad, _) {
      ad.dispose();
      _loadInterstitialAd();
    });
    _interstitialAd!.show();
    _interstitialAd = null;
  }

