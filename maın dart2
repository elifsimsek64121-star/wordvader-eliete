            child: ClipRRect(
              borderRadius: BorderRadius.circular(19),
              child: GestureDetector(
                behavior: HitTestBehavior.opaque,
                onPanStart: (d) => _onPanStart(d, cs),
                onPanUpdate: (d) => _onPanUpdate(d, cs),
                onPanEnd: _onPanEnd,
                child: Stack(
                  children: [
                    // Izgara arka planı
                    Container(
                      color: AppColors.gridBg,
                    ),
                    // Hücreler
                    GridView.builder(
                      physics: const NeverScrollableScrollPhysics(),
                      gridDelegate: SliverGridDelegateWithFixedCrossAxisCount(
                          crossAxisCount: gridSize,
                          mainAxisSpacing: 0,
                          crossAxisSpacing: 0),
                      itemCount: gridSize * gridSize,
                      itemBuilder: (_, idx) {
                        final r = idx ~/ gridSize, c = idx % gridSize;
                        return _buildCell(r, c, cs);
                      },
                    ),
                    // Çizilen yollar
                    CustomPaint(
                        painter: _WordLinePainter(
                            drawnPaths, cs, isPaused ? 0.4 : 0.9),
                        size: Size(gridPx, gridPx)),
                    // Sürükleme önizleme
                    if (_dragStartRow != null &&
                        _dragEndRow != null &&
                        !isPaused)
                      CustomPaint(
                          painter: _WordLinePainter([
                            {
                              'color': Colors.white.withOpacity(0.45),
                              'cells': _cellsInLine(_dragStartRow!,
                                  _dragStartCol!, _dragEndRow!, _dragEndCol!)
                            }
                          ], cs, 0.7, isDashed: true),
                          size: Size(gridPx, gridPx)),
                  ],
                ),
              ),
            ),
          ),
        ),
      ),
    );
  }

  // ── HÜCRE — Büyük, okunabilir harfler ────────────────────────────────────
  Widget _buildCell(int r, int c, double cs) {
    final path = drawnPaths.firstWhere(
        (p) => (p['cells'] as List<Offset>)
            .any((o) => o.dx.toInt() == c && o.dy.toInt() == r),
        orElse: () => <String, dynamic>{});

    final inDrag = _dragStartRow != null &&
        _dragEndRow != null &&
        _cellsInLine(_dragStartRow!, _dragStartCol!, _dragEndRow!, _dragEndCol!)
            .any((o) => o.dx.toInt() == c && o.dy.toInt() == r);

    final isPulsing = path.isNotEmpty && pulsingWords.contains(path['word']);

    // Izgara çizgileri için çok ince border
    final isLastCol = c == gridSize - 1;
    final isLastRow = r == gridSize - 1;

    return AnimatedBuilder(
      animation: _pulseCtrl,
      builder: (_, __) {
        Color bgColor;
        Color letterColor;
        List<Shadow>? shadows;

        if (path.isNotEmpty) {
          final pathColor = path['color'] as Color;
          final pulse = isPulsing ? 0.28 + 0.22 * _pulseCtrl.value : 0.20;
          bgColor = pathColor.withOpacity(pulse);
          letterColor = pathColor;
          shadows = [
            Shadow(color: pathColor.withOpacity(0.8), blurRadius: 10),
          ];
        } else if (inDrag) {
          bgColor = Colors.white.withOpacity(0.14);
          letterColor = AppColors.textPrimary;
          shadows = null;
        } else {
          bgColor = Colors.transparent;
          letterColor = AppColors.textPrimary.withOpacity(0.88);
          shadows = null;
        }

        // Harf büyüklüğü: ızgara küçüldükçe harf de küçülür ama minimum okunabilir kalır
        final fontSize = (cs * 0.46).clamp(11.0, 26.0);

        return Container(
          decoration: BoxDecoration(
            color: bgColor,
            border: Border(
              right: isLastCol
                  ? BorderSide.none
                  : BorderSide(
                      color: AppColors.gridCellBorder.withOpacity(0.5),
                      width: 0.5),
              bottom: isLastRow
                  ? BorderSide.none
                  : BorderSide(
                      color: AppColors.gridCellBorder.withOpacity(0.5),
                      width: 0.5),
            ),
          ),
          child: Center(
            child: Text(
              grid[r][c],
              style: TextStyle(
                fontSize: fontSize,
                fontWeight: FontWeight.w900,
                color: letterColor,
                shadows: shadows,
                height: 1,
              ),
            ),
          ),
        );
      },
    );
  }

  // ── ALT BAR — Joker ve ipucu butonları ────────────────────────────────────
  Widget _buildBottomBar(double cs) {
    return Padding(
