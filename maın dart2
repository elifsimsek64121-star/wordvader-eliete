class PremiumScreen extends StatefulWidget {
  final String lang;
  final Function(int, bool) onPurchase;

  const PremiumScreen(
      {super.key, required this.lang, required this.onPurchase});

  @override
  State<PremiumScreen> createState() => _PremiumScreenState();
}

class _PremiumScreenState extends State<PremiumScreen> {
  final InAppPurchase _iap = InAppPurchase.instance;
  StreamSubscription<List<PurchaseDetails>>? _sub;
  List<ProductDetails> _products = [];
  bool _isAvailable = false;
  bool _isLoading = true;

  static const _removeAdsAndroid = 'remove_ads';
  static const _removeAdsIOS = 'remove_ads_ios';

  static const _packagesAndroid = {
    'coin_250': {'coins': 250, 'bonus': '', 'popular': false},
    'coin_750': {'coins': 750, 'bonus': '', 'popular': false},
    'coin_1600': {'coins': 1600, 'bonus': '+25%', 'popular': false},
    'coin_3600': {'coins': 3600, 'bonus': '+45%', 'popular': true},
    'coin_8000': {'coins': 8000, 'bonus': '+60%', 'popular': false},
    'remove_ads': {'coins': 0, 'bonus': '', 'popular': false},
  };

  static const _packagesIOS = {
    'coin_250_ios': {'coins': 250, 'bonus': '', 'popular': false},
    'coin_750_ios': {'coins': 750, 'bonus': '', 'popular': false},
    'coin_1600_ios': {'coins': 1600, 'bonus': '+25%', 'popular': false},
    'coin_3600_ios': {'coins': 3600, 'bonus': '+45%', 'popular': true},
    'coin_8000_ios': {'coins': 8000, 'bonus': '+60%', 'popular': false},
    'remove_ads_ios': {'coins': 0, 'bonus': '', 'popular': false},
  };

  late final Map<String, dynamic> _packages;
  late final Set<String> _productIds;

  @override
  void initState() {
    super.initState();
    _packages = Map<String, dynamic>.from(
        Platform.isAndroid ? _packagesAndroid : _packagesIOS);
    _productIds = _packages.keys.toSet();
    _init();
  }

  Future<void> _init() async {
    final available = await _iap.isAvailable();
    if (!mounted) return;
    if (!available) {
      setState(() {
        _isLoading = false;
        _isAvailable = false;
      });
      return;
    }
    _isAvailable = true;
    _sub = _iap.purchaseStream
        .listen(_onPurchase, onError: (e) => debugPrint('IAP error: $e'));
    try {
      final resp = await _iap.queryProductDetails(_productIds);
      if (mounted)
        setState(() {
          _products = resp.productDetails;
          _isLoading = false;
        });
    } catch (e) {
      debugPrint('queryProductDetails: $e');
      if (mounted) setState(() => _isLoading = false);
    }
  }

  void _onPurchase(List<PurchaseDetails> purchases) async {
    final prefs = await SharedPreferences.getInstance();

    for (final p in purchases) {
      if (p.status == PurchaseStatus.purchased ||
          p.status == PurchaseStatus.restored) {
        int coins = 0;
        bool removeAds = false;
        final id = p.productID;
        if (id == _removeAdsAndroid || id == _removeAdsIOS) {
          removeAds = true;
          await prefs.setBool('ads_removed', true);
        } else if (_packages.containsKey(id)) {
          coins = (_packages[id]?['coins'] as num?)?.toInt() ?? 0;
        }
        widget.onPurchase(coins, removeAds);

        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(SnackBar(
              content: const Text('Purchase successful! 🎉'),
              backgroundColor: AppColors.success,
              shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(12)),
              behavior: SnackBarBehavior.floating,
              margin: const EdgeInsets.all(20)));
        }
      }
      if (p.pendingCompletePurchase) {
        try {
          await _iap.completePurchase(p);
        } catch (e) {
          debugPrint('completePurchase: $e');
        }
      }
    }
  }

  Future<void> _buy(ProductDetails product) async {
    final param = PurchaseParam(productDetails: product);
    try {
      if (product.id == _removeAdsAndroid || product.id == _removeAdsIOS) {
        await _iap.buyNonConsumable(purchaseParam: param);
      } else {
        await _iap.buyConsumable(purchaseParam: param, autoConsume: true);
      }
    } catch (e) {
      debugPrint('buyProduct: $e');
    }
  }

  @override
  void dispose() {
    _sub?.cancel();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: AppColors.bg1,
      body: Stack(
        children: [
          const StarfieldBackground(),
          SafeArea(
            child: Column(
              children: [
                Padding(
                  padding: const EdgeInsets.fromLTRB(16, 16, 16, 0),
                  child: Row(
                    children: [
                      _IconCircleButton(
                          icon: Icons.arrow_back_ios_new_rounded,
                          onTap: () => Navigator.pop(context)),
                      const Spacer(),
                      ShaderMask(
                          shaderCallback: (b) => const LinearGradient(colors: [
                                AppColors.textPrimary,
                                AppColors.gold
                              ]).createShader(b),
                          child: const Text('STORE',
                              style: TextStyle(
                                  fontFamily: 'Georgia',
                                  fontSize: 22,
                                  fontWeight: FontWeight.w900,
                                  color: Colors.white,
                                  letterSpacing: 4))),
                      const Spacer(),
                      _IconCircleButton(
                          icon: Icons.restore_rounded,
                          onTap: () async {
                            await _iap.restorePurchases();
                            if (mounted)
                              ScaffoldMessenger.of(context).showSnackBar(
                                  const SnackBar(
                                      content: Text('Restoring purchases...'),
                                      behavior: SnackBarBehavior.floating));
                          }),
                    ],
                  ),
                ),
                const SizedBox(height: 24),
                Expanded(
                  child: _isLoading
                      ? const Center(
                          child:
                              CircularProgressIndicator(color: AppColors.gold))
                      : !_isAvailable || _products.isEmpty
                          ? _EmptyStore()
                          : ListView(
                              padding: const EdgeInsets.fromLTRB(20, 0, 20, 40),
                              physics: const BouncingScrollPhysics(),
                              children: [
                                Padding(
                                    padding: const EdgeInsets.only(bottom: 16),
                                    child: Row(children: [
                                      const Icon(Icons.monetization_on_rounded,
                                          color: AppColors.gold, size: 18),
                                      const SizedBox(width: 8),
                                      Text('COIN PACKAGES',
                                          style: AppTextStyles.labelSmall
                                              .copyWith(
                                                  color: AppColors.gold,
                                                  letterSpacing: 2))
                                    ])),
                                ..._products
                                    .where((p) =>
                                        p.id != _removeAdsAndroid &&
                                        p.id != _removeAdsIOS)
                                    .map((p) {
                                  final info = _packages[p.id] as Map?;
                                  final bonus = info?['bonus'] as String? ?? '';
                                  final isPopular = info?['popular'] == true;
                                  final coins =
                                      (info?['coins'] as num?)?.toInt() ?? 0;
                                  return Padding(
                                      padding:
                                          const EdgeInsets.only(bottom: 12),
                                      child: _ProductCard(
                                          product: p,
                                          coins: coins,
                                          bonus: bonus,
                                          isPopular: isPopular,
                                          onBuy: () => _buy(p)));
                                }),
                                const SizedBox(height: 24),
                                Padding(
                                    padding: const EdgeInsets.only(bottom: 16),
                                    child: Row(children: [
                                      const Icon(Icons.workspace_premium,
                                          color: AppColors.accentLight,
                                          size: 18),
                                      const SizedBox(width: 8),
                                      Text('PREMIUM',
                                          style: AppTextStyles.labelSmall
                                              .copyWith(
                                                  color: AppColors.accentLight,
                                                  letterSpacing: 2))
                                    ])),
                                ..._products
                                    .where((p) =>
                                        p.id == _removeAdsAndroid ||
                                        p.id == _removeAdsIOS)
                                    .map((p) => _RemoveAdsCard(
                                        product: p, onBuy: () => _buy(p))),
                              ],
                            ),
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }
}

