  List<Map<String, dynamic>> drawnPaths = [];
  Set<String> pulsingWords = {};
  int? _dragStartRow, _dragStartCol, _dragEndRow, _dragEndCol;

  late AnimationController _pulseCtrl;
  late AnimationController _successCtrl;
  late Animation<double> _successScale;

  // Izgara giriş animasyonu
  late AnimationController _gridEnterCtrl;
  late Animation<double> _gridEnterAnim;

  String? _lastFoundWord;
  Timer? _gameTimer;
