class _HomeScreenState extends State<HomeScreen> with TickerProviderStateMixin {
  String lang = 'en';
  Map<String, String> t = {};
  int coins = 0;
  int level = 1;
  int totalScore = 0;
  bool adsRemoved = false;
  bool _dailyAvailable = false;

  late AnimationController _enterCtrl;
  late AnimationController _floatCtrl;
  List<Animation<double>> _itemAnims = [];

  static const List<double> _animStarts = [0.0, 0.12, 0.24, 0.36, 0.48];
  static const List<double> _animEnds = [0.50, 0.62, 0.74, 0.86, 1.0];

  @override
  void initState() {
    super.initState();
    t = translations[lang]!;

    _enterCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 1200));
    _floatCtrl =
        AnimationController(vsync: this, duration: const Duration(seconds: 3))
          ..repeat(reverse: true);

    _itemAnims = List.generate(
        5,
        (i) => Tween<double>(begin: 0.0, end: 1.0).animate(CurvedAnimation(
            parent: _enterCtrl,
            curve: Interval(_animStarts[i], _animEnds[i],
                curve: Curves.easeOutCubic))));

    _enterCtrl.forward();
    _loadData();
  }

  Future<void> _loadData() async {
    final prefs = await SharedPreferences.getInstance();
    if (!mounted) return;

    final lastReward = prefs.getString('last_daily_reward');
    final today = DateTime.now().toIso8601String().substring(0, 10);

    setState(() {
      coins = prefs.getInt('coins') ?? 0;
      level = prefs.getInt('level') ?? 1;
      totalScore = prefs.getInt('score') ?? 0;
      adsRemoved = prefs.getBool('ads_removed') ?? false;
      _dailyAvailable = lastReward != today;
    });
  }

  Future<void> _claimDailyReward() async {
    if (!_dailyAvailable) {
      _showToast(t['daily_claimed']!);
      return;
    }
    final prefs = await SharedPreferences.getInstance();
    final today = DateTime.now().toIso8601String().substring(0, 10);
    setState(() {
      coins += 50;
      _dailyAvailable = false;
    });
    await prefs.setInt('coins', coins);
    await prefs.setString('last_daily_reward', today);
    if (mounted) _showDailyRewardDialog();
  }

  void _showDailyRewardDialog() {
    showDialog(
        context: context,
        barrierColor: Colors.black.withOpacity(0.7),
        builder: (_) => _DailyRewardDialog(t: t));
