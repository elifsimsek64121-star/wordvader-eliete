class _PowerButton extends StatelessWidget {
  final String label;
  final int count;
  final IconData icon;
  final Color color;
  final VoidCallback? onTap;
  final AnimationController pulseCtrl;

  const _PowerButton(
      {required this.label,
      required this.count,
      required this.icon,
      required this.color,
      required this.onTap,
      required this.pulseCtrl});

  @override
  Widget build(BuildContext context) {
    final hasCount = count > 0;
    final canTap = onTap != null;

    return GestureDetector(
      onTap: onTap,
      child: AnimatedContainer(
        duration: const Duration(milliseconds: 250),
        padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
        decoration: BoxDecoration(
            color: hasCount
                ? color.withOpacity(0.18)
                : AppColors.surface.withOpacity(0.6),
            borderRadius: BorderRadius.circular(16),
            border: Border.all(
                color:
                    hasCount ? color.withOpacity(0.6) : AppColors.borderBright,
                width: hasCount ? 1.5 : 1),
            boxShadow: hasCount
                ? [BoxShadow(color: color.withOpacity(0.25), blurRadius: 16)]
                : null),
        child: Row(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Stack(
              clipBehavior: Clip.none,
              children: [
                AnimatedBuilder(
                  animation: pulseCtrl,
                  builder: (_, __) => Transform.scale(
                      scale: hasCount && canTap
                          ? 0.88 + 0.18 * pulseCtrl.value
                          : 1.0,
                      child: Icon(icon,
                          color: hasCount ? color : AppColors.textMuted,
                          size: 22)),
                ),
                Positioned(
                  top: -6,
                  right: -8,
                  child: AnimatedContainer(
                    duration: const Duration(milliseconds: 300),
                    padding:
                        const EdgeInsets.symmetric(horizontal: 5, vertical: 2),
                    decoration: BoxDecoration(
                        color: hasCount ? color : AppColors.textMuted,
                        borderRadius: BorderRadius.circular(10),
                        boxShadow: hasCount
                            ? [
                                BoxShadow(
                                    color: color.withOpacity(0.4),
                                    blurRadius: 6)
                              ]
                            : null),
                    child: Text('$count',
                        style: const TextStyle(
                            fontSize: 10,
                            fontWeight: FontWeight.w900,
                            color: Colors.white)),
                  ),
                ),
              ],
            ),
            const SizedBox(width: 10),
            Flexible(
              child: Column(
                mainAxisSize: MainAxisSize.min,
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(label,
                      style: TextStyle(
                          fontSize: 13,
                          fontWeight: FontWeight.w700,
                          color: hasCount
                              ? AppColors.textPrimary
                              : AppColors.textMuted),
                      overflow: TextOverflow.ellipsis),
                  const SizedBox(height: 2),
                  AnimatedSwitcher(
                    duration: const Duration(milliseconds: 250),
                    child: hasCount
                        ? Row(
                            key: const ValueKey('has'),
                            mainAxisSize: MainAxisSize.min,
                            children: [
                                Icon(Icons.check_circle_rounded,
                                    color: color, size: 11),
                                const SizedBox(width: 3),
                                Text('$count adet',
                                    style: TextStyle(
                                        fontSize: 11,
                                        color: color,
                                        fontWeight: FontWeight.w700))
                              ])
                        : Row(
                            key: const ValueKey('buy'),
                            mainAxisSize: MainAxisSize.min,
                            children: [
                                const Icon(Icons.monetization_on_rounded,
                                    color: AppColors.gold, size: 11),
                                const SizedBox(width: 3),
                                const Text('50 coin',
                                    style: TextStyle(
                                        fontSize: 11,
                                        color: AppColors.gold,
                                        fontWeight: FontWeight.w700))
                              ]),
                  ),
                ],
              ),
            ),
          ],
        ),
      ),
    );
  }
}

